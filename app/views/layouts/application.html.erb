<!DOCTYPE html>
<html>
  <head>
    <title>My Bookmark App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
 </head>
  <body>
    <header>
      <h1>ブックマークアプリ</h1>
      <nav>
        <%= link_to 'ホーム', root_path %>
      </nav>
    </header>

    <div class="container">
      <aside class="sidebar">
        <h3>最近のブックマーク</h3>
        <ul>
          <% Bookmark.order(created_at: :desc).limit(5).each do |bookmark| %>
            <li><%= link_to bookmark.title, bookmark %></li>
          <% end %>
        </ul>
      </aside>

      <main class="content">
        <%= yield %>
      </main>
    </div>

    <footer>
      <p>&copy; 2025 ブックマークアプリ</p>
    </footer>
  </body>
</html>
